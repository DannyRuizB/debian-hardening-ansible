# Managed by debian-hardening-ansible (sysctl_hardening role).
# Edit the role variables, not this file — changes here will be overwritten.
#
# Deliberately NOT set here, to keep the "won't lock you out" promise:
#   net.ipv6.conf.*.accept_ra  — would break IPv6 SLAAC on many VPSes
#   net.ipv4.ip_forward        — would break routers / Docker hosts
{% for key, value in sysctl_hardening_keys.items() %}
{{ key }} = {{ value }}
{% endfor %}
