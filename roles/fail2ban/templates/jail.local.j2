# Managed by debian-hardening-ansible (fail2ban role).
# Edit the role variables, not this file — changes here will be overwritten.
[DEFAULT]
# Ban via UFW, and read the journal instead of a log file (Debian default).
banaction = ufw
backend   = systemd

[sshd]
enabled  = true
port     = {{ fail2ban_ssh_port }}
bantime  = {{ fail2ban_bantime }}
findtime = {{ fail2ban_findtime }}
maxretry = {{ fail2ban_maxretry }}
# OpenSSH >= 9.8 splits auth into an 'sshd-session' process, so the stock
# filter's '_COMM=sshd' journal match misses 'Invalid user' failures and never
# bans them. Match on the ssh unit alone (covers sshd and sshd-session).
journalmatch = _SYSTEMD_UNIT=ssh.service
