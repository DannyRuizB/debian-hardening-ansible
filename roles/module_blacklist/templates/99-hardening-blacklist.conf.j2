# Managed by debian-hardening-ansible (module_blacklist role).
# Edit the role variables, not this file — changes here will be overwritten.
#
# Keep rarely-used kernel modules unloadable (CIS 1.1.1 / 3.4). Two
# directives per module because they close different doors: `install`
# defeats an explicit modprobe, `blacklist` stops alias auto-loading.
{% for m in module_blacklist_modules %}
install {{ m }} /bin/false
blacklist {{ m }}
{% endfor %}
